# ===== MayaSec backend — .env.example =====
# Copie para .env no prod2 e preencha com valores REAIS. NUNCA comite o .env real.

# --- App ---
ENVIRONMENT=production
DEBUG=false
# 8001 e 3000 já estão ocupadas no prod2 (PilatesFinal/Flicsales) -> usamos 8011 e 3001
API_PORT=8011
CORS_ORIGINS=http://localhost:3001

# --- Banco (Postgres já existe no prod2; só crie o DB `mayasec`) ---
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@localhost:5432/mayasec

# --- Provedor de IA: openai | gemini ---
AI_PROVIDER=openai

# --- OpenAI (núcleo IA) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Gemini (alternativa) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- WaSenderAPI (gateway WhatsApp) ---
WASENDER_API_KEY=
WASENDER_BASE_URL=https://wasenderapi.com/api
# URL pública do backend (pra WaSender baixar mídia enviada pelo painel)
PUBLIC_BASE_URL=http://2.25.130.240:8011
WASENDER_WEBHOOK_SECRET=
# Verificação da assinatura do webhook (deixe false até confirmar o formato real)
WASENDER_VERIFY_SIGNATURE=false
WASENDER_SIGNATURE_MODE=hmac_sha256   # hmac_sha256 | plain
WASENDER_SIGNATURE_HEADER=X-Wasender-Signature

# --- Auth do painel (JWT) ---
JWT_SECRET=troque-por-um-segredo-aleatorio-forte
JWT_EXPIRE_MINUTES=720

# --- Criptografia Fernet das credenciais por tenant ---
# Gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_MASTER_KEY=

# --- Anti-flood (defaults globais; tenant pode sobrescrever) ---
ANTIFLOOD_MAX_MSGS=5
ANTIFLOOD_WINDOW_SECONDS=30
