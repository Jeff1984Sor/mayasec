# ===== MayaSec frontend — .env.local.example =====
# Copie para .env.local no prod2.

# URL do backend acessível PELO NAVEGADOR (client-side fetch das telas)
NEXT_PUBLIC_API_BASE_URL=http://SEU_IP:8011

# URL do backend acessível PELO SERVIDOR Next (NextAuth authorize, server-side)
API_BASE_URL=http://localhost:8011

# NextAuth
NEXTAUTH_URL=http://SEU_IP:3001
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-um-segredo-aleatorio-forte
